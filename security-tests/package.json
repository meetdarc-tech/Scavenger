{
  "name": "scavenger-security-tests",
  "version": "1.0.0",
  "description": "Security testing suite for Scavenger platform",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --include '**/*.integration.test.ts'",
    "test:security": "vitest run && npm run scan:zap",
    "scan:zap": "node scripts/zap-scan.js",
    "lint": "eslint . --ext ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "node-fetch": "^3.3.2"
  }
}
