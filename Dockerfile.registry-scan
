#!/bin/bash

# Docker security scanning configuration
# Runs trivy security scan on images before pushing to registry

set -e

IMAGE_NAME=${1:-scavenger-backend}
IMAGE_TAG=${2:-latest}
REGISTRY=${3:-docker.io}

echo "🔍 Running security scan on ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}..."

# Install trivy if not present
if ! command -v trivy &> /dev/null; then
    echo "Installing trivy..."
    apt-get update && apt-get install -y wget
    wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key | apt-key add -
    echo "deb https://aquasecurity.github.io/trivy-repo/deb $(lsb_release -sc) main" | tee /etc/apt/sources.list.d/trivy.list
    apt-get update && apt-get install -y trivy
fi

# Scan image
trivy image --severity HIGH,CRITICAL --exit-code 1 "${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}" || {
    echo "❌ Security scan failed with critical vulnerabilities"
    exit 1
}

echo "✅ Security scan passed"
